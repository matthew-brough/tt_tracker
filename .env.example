# Cloudflare Tunnel
CF_CREDS_PATH=          # absolute host path to creds.json
CF_TUNNEL_ID=           # tunnel UUID or name

# Postgres
POSTGRES_DB=tt_tracker
POSTGRES_USER=
POSTGRES_PASSWORD=

# Redis (optional — leave empty for no auth)
REDIS_PASSWORD=

# Collector
TYCOON_API_KEY=
TYCOON_SERVERS=main:https://api.tycoon.community,beta:https://apibeta.tycoon.community
POLL_INTERVAL_MS=10000
FLUSH_INTERVAL_MS=15000

# API
API_PORT=8080
